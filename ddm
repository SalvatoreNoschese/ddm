	_ddev_start || return 1

	_info "Installing Drupal via Composer & Drush..."
	ddev composer create-project "drupal/recommended-project:^${ver}" || {
		_error "Drupal composer create failed"
		return 1
	}
	ddev composer require drush/drush || {
		_error "Drush install failed"
		return 1
	}
	ddev drush site:install --account-name=admin --account-pass=admin -y || {
		_error "Drupal site:install failed"
		return 1
	}

	_finalize_installation "$name" "admin" "admin" ""
