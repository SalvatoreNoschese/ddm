# WordPress
install_wordpress() {
	local name="$1"
	_setup_project_dir "$name" || return 1

	_info "Configuring WordPress..."
	ddev config --project-type=wordpress || {
		_error "DDEV config failed"
		return 1
	}
	_ddev_start || return 1

	_info "Downloading & Installing WordPress..."
	ddev wp core download || {
		_error "WordPress download failed"
		return 1
	}

	_info "Running WordPress site:install..."
	ddev wp core install --url="https://${name}.ddev.site" --title="Dev WP" \
		--admin_user=admin --admin_password=admin --admin_email=admin@example.com || {
			_error "WordPress install failed"
			return 1
		}

	_finalize_installation "$name" "admin" "admin" ""
}

