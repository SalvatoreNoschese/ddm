# Returns 0 if running on an Android kernel (e.g. inside Termux or UserLAnd).
_is_android() {
	[[ "$(uname -r 2>/dev/null || true)" == *android* ]] ||
		[[ "$(uname -a 2>/dev/null || true)" == *" Android"* ]] ||
		[[ "$(uname -a 2>/dev/null || true)" == *android* ]]
}

# Returns 0 if xdg-open is available and a display environment is present.
_can_launch() {
	command -v xdg-open >/dev/null 2>&1 && \
		{ [[ -n "${DISPLAY:-}" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; }
}

