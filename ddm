# ====================================================================== #
# Runs post-installation steps shared by all installers:                 #
#  1. Optionally installs a DB manager add-on (phpMyAdmin or Adminer)    #
#  2. Prints the project URLs                                            #
#  3. Shows default credentials (when provided)                          #
#  4. Prints any extra notes                                             #
#  5. Opens the project in the browser                                   #
#                                                                        #
# Parameters:                                                            #
#  $1  name     - DDEV project name                                      #
#  $2  username - admin username (empty string to skip credential block) #
#  $3  password - admin password (empty string to skip credential block) #
#  $4  notes    - extra message shown after credentials (empty to skip)  #
# ====================================================================== #
_finalize_installation() {
	local name="$1" username="${2:-}" password="${3:-}" notes="${4:-}" nodb="${5:-}"
	_restart() { ddev restart || _warn "Failed to run 'ddev restart' (non-critical)"; }

	if [[ "$nodb" != "nodb" ]]; then
		printf "%s\n" "Install a database manager? ${B}[default: * > None]${NC}"
		printf "%s\n" " ${G}[1]${NC} Adminer"
		printf "%s\n" " ${G}[2]${NC} phpMyAdmin"
		printf "%s\n\n" " ${B}[*]${NC} None (skip: default)"
		local db_choice
		db_choice="$(_read_input "Choice [1/2/*]" "*")"
		case "$db_choice" in
		1)
			_info "Installing Adminer..."
			if ddev add-on get ddev/ddev-adminer; then
				_invalidate_ddev_cache
				_restart
				_done "Adminer installed!"
			else
				_warn "Adminer installation failed (non-critical)"
			fi
			;;
		2)
			_info "Installing phpMyAdmin..."
			if ddev add-on get ddev/ddev-phpmyadmin; then
				_invalidate_ddev_cache
				_restart
				_done "phpMyAdmin installed!"
			else
				_warn "phpMyAdmin installation failed (non-critical)"
			fi
			;;
		*)
			_info "Skipping database manager."
			;;
		esac
	fi

	_nl
	_done "Project '$name' successfully created!"
	_show_project_urls "$name"

	if [[ -n "$username" && -n "$password" ]]; then
		_printbox "$Y" "DEFAULT CREDENTIALS"
		_info "Username: ${G}$username${NC}"
		_info "Password: ${G}$password${NC}"
		_warn "SAVE THESE NOW: not shown in project menus!"
		_say "$Y" "OK for local dev ONLY: change for production!"
		_nl
	fi

	[[ -n "$notes" ]] && _info "$notes"

	if _can_launch; then
		project_open "$name" || true
	else
		_warn "Cannot launch browser on this system"
	fi
	_presskey
}

# ============= #
# INPUT HELPERS #
# ============= #

# Prompts a yes/no question with a configurable default.
# Usage: _prompt_yes_no "Question?" "Y"|"N"
# Returns 0 for yes, 1 for no.
_prompt_yes_no() {
	local prompt="$1" default="${2:-Y}" choice=""
	if [[ "$default" == "Y" ]]; then
		read -r -p "$prompt [Y/n]: " choice
		[[ -z "$choice" || "$choice" =~ ^[Yy] ]]
	else
		read -r -p "$prompt [y/N]: " choice
		[[ "$choice" =~ ^[Yy] ]]
	fi
}

# Reads a non-empty input string, re-prompting on blank input.
# Usage: var=$(_read_input "Label" [default])
_read_input() {
	local prompt="${1:-Choice}" default="${2:-}" choice=""
	while true; do
		read -r -p "$prompt: " choice
		choice="${choice:-$default}"
		if [[ -n "${choice//[[:space:]]/}" ]]; then
			echo "$choice"
			return 0
		fi
		_warn "Empty input. Please try again." >&2
	done
}

# Pauses execution until the user presses any key.
# Usage: _presskey [action_verb] (defaults to "continue")
_presskey() {
	local msg="${1:-continue}"
	_nl
	read -r -n 1 -p "Press any key to $msg..."
}

# Displays a "going back" notice with a brief pause for UX feedback.
# Usage: _back; return 0
_back() {
	_info "Going back..."
	sleep .5
}

# Confirms whether the user wants to exit DDM.
# Calls exit 0 on confirmation; prints an abort notice and returns otherwise.
# Usage: _exit  (inside a case/while loop)
_exit() {
	if _prompt_yes_no "Exit DDM?" "N"; then
		exit 0
	fi
	_info "Exit aborted."
	sleep .5
}

