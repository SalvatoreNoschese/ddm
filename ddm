# Guides the user through selecting a project type and naming the project,
# then delegates to the corresponding install_* function.
create_project() {
	while true; do
		clear
		_printbox "$C" "Create New Project"
		printf "%s\n\n" "${B}Available Project Types:${NC}"

		local i=1
		local prev_cat=""
		local -a indexed_entries=()
		local -A t

		for entry in "${PROJECT_TYPES[@]}"; do
			_parse_type_entry "$entry" t
			# Print category header when category changes
			if [[ "${t[cat]}" != "$prev_cat" ]]; then
				case "${t[cat]}" in
				cms)       printf "%s\n" " ${M}───────── CMS ─────────${NC}" ;;
				framework) printf "%s\n" " ${M}────── Framework ──────${NC}" ;;
				extra)     printf "%s\n" " ${M}──────── Extra ────────${NC}" ;;
				esac
				prev_cat="${t[cat]}"
			fi
			printf " ${G}%2d)${NC} ${C}%s${NC}\n" "$i" "${t[label]}"
			indexed_entries+=("$entry")
			((i++))
		done

		printf "\n%s\n\n" " ${M}[b]${NC}ack   [e]xit"
		_nl

		local type_choice=""
		local total="${#indexed_entries[@]}"

		while true; do
			type_choice="$(_read_input "Select type (1-${total})")"

			case "$type_choice" in
			q | quit | e | x | exit)
				_exit
				continue
				;;
			b | back)
				_back
				return 0
				;;
			esac

			if [[ "$type_choice" =~ ^[0-9]+$ ]] &&
				[[ "$type_choice" -ge 1 ]] &&
				[[ "$type_choice" -le "$total" ]]; then
				break
			fi

			_error "Invalid selection. Try again."
		done

		local selected_entry="${indexed_entries[$((type_choice - 1))]}"
		_parse_type_entry "$selected_entry" t   # reuse t declared above

		_nl
		local project_name=""
		local full_name=""
		local project_path=""
		while true; do
			read -r -p "Project name (prefixed with '${t[prefix]}'): ${t[prefix]}-" project_name

			case "$project_name" in
			b | back)
				_back
				return 0
				;;
			q | quit | e | x | exit)
				_exit
				continue
				;;
			esac

			project_name="$(echo "$project_name" | tr '[:upper:]' '[:lower:]' | tr -c '[:alnum:]-' '-' | sed -E 's/-+/-/g; s/^-|-$//g')"

			if [[ -z "$project_name" ]]; then
				_error "Name cannot be empty"
				continue
			fi

			if [[ ! "$project_name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
				_error "Invalid name. Use only lowercase letters, numbers, and hyphens."
				continue
			fi

			full_name="${t[prefix]}-$project_name"

			# Check 1: project already registered in DDEV.
			local existing_status
			existing_status="$(_get_project_status "$full_name")"
			if [[ -n "$existing_status" ]]; then
				_warn "Project '$full_name' already exists [$existing_status]"
				_info "Please choose a different name."
				continue
			fi

			# Check 2: directory exists but project is not registered (orphaned).
			project_path="$DDEV_DIR/$full_name"
			if [[ -d "$project_path" ]]; then

				if [[ -d "$project_path/.ddev" ]]; then
					_warn "Directory exists but project not in DDEV: $project_path"
					_info "Found DDEV configuration in directory."

					if _prompt_yes_no "Re-import this project to DDEV?" "Y"; then
						cd "$project_path" || {
							_error "Cannot access directory"
							continue
						}

						_info "Starting project to re-register with DDEV..."
						if ddev start; then
							_done "Project re-imported successfully!"
							_show_project_urls "$full_name"
							project_open "$full_name"
							_presskey
							return 0
						else
							_error "Failed to start project"
							continue
						fi
					fi
					continue
				fi

				_warn "Directory exists but has no DDEV config: $project_path"
				printf "\n%s\n" "${G}[1]${NC} Reuse this directory (install into it)"
				printf "%s\n" "${B}[2]${NC} Choose a different name or remove it manually:"
				_say "$Y" "rm -rf \"$project_path\""
				_nl
				local dir_choice
				dir_choice="$(_read_input "Choice [1/2]")"
				case "$dir_choice" in
				1)
					_info "Reusing existing directory..."
					break
					;;
				*)
					continue
					;;
				esac
			fi

			break
		done

		_nl
		_info "Creating: $full_name ($(_type_label_from_prefix "$full_name"))"
		_nl
		if ! _prompt_yes_no "Proceed?" "Y"; then
			_warn "Cancelled by user"
			return 0
		fi

		local install_func="install_${t[key]//-/_}"

		if ! declare -f "$install_func" &>/dev/null; then
			_error "Installer function not found: $install_func"
			return 1
		fi

		if ! "$install_func" "$full_name"; then
			_nl
			_error "Installation failed for '$full_name'."
			_troubleshoot
			_nl
			_presskey
			return 1
		fi
		_nl
		return 0
	done
}

# Displays the interactive per-project menu and dispatches project actions.
# The outer loop re-renders the menu after each action (status may have changed).
# Inner loop: handles input without re-rendering.
# - break    -> re-render the outer loop (refreshed status)
# - return 0 -> exit back to the project list
manage_project() {
	local name="$1"

	while true; do
		clear
		_invalidate_ddev_cache

		local status
		status="$(_get_project_status "$name")"

		if [[ -z "$status" ]]; then
			_error "Project not found: $name"
			return 1
		fi

		local display_type
		display_type="$(_type_label_from_prefix "$name")"

		local boxcolor="$R"
		[[ "$status" == "running" ]] && boxcolor="$G"
		[[ "$status" == "paused" ]] && boxcolor="$Y"

		_printbox "$boxcolor" "$name - $display_type [$status]"

		_show_project_urls "$name"

		local line1 line2=""
		local wipe_action=""
		_project_has_db "$name" && wipe_action="${R}[w]${NC}ipe(db)   "

		local back_opt="${M}[b]${NC}ack   "

		if [[ "$status" == "running" ]]; then
			if _can_launch; then
				line1="${G}[o]${NC}pen       ${Y}[s]${NC}top       ${Y}[r]${NC}estart   ${B}[i]${NC}nfo"
			else
				line1="${Y}[s]${NC}top       ${Y}[r]${NC}estart    ${B}[i]${NC}nfo"
			fi
			line2="${C}[t]${NC}erminal   ${wipe_action}${R}[d]${NC}elete    ${back_opt}[e]xit"
		else
			line1="${G}[s]${NC}tart  ${B}[i]${NC}nfo  ${wipe_action}${R}[d]${NC}elete"
			line2="${back_opt}[e]xit"
		fi

		printf "\n%s\n" "$line1"
		[[ -n "$line2" ]] && printf "%s\n" "$line2"
		_nl

		while true; do
			local choice
			choice="$(_read_input "Choice")"

			case "$choice" in
			o | open)
				if _can_launch; then
					project_open "$name"
				else
					_warn "Browser not available (xdg-open missing or no GUI session detected)."
				fi
				break
				;;

			i | info)
				_info "Loading project info..."
				sleep .5
				clear
				project_describe "$name"
				break
				;;

			t | terminal | ssh)
				_info "Opening terminal..."
				sleep .5
				clear
				project_ssh "$name"
				break
				;;

			s)
				_info "Please be patient..."
				sleep .5
				clear
				if [[ "$status" == "running" ]]; then
					project_stop "$name"
				else
					project_start "$name"
				fi
				break
				;;

			start)
				_info "Please be patient..."
				sleep .5
				if [[ "$status" == "running" ]]; then
					_say "$B" "Project is already running: $name"
					continue
				else
					clear
					project_start "$name"
					break
				fi
				;;
			stop)
				_info "Please be patient..."
				sleep .5
				if [[ "$status" != "running" ]]; then
					_say "$Y" "Project is not running (status: ${Y}${status:-unknown}${NC})"
					continue
				else
					clear
					project_stop "$name"
					break
				fi
				
				;;

			r | restart)
				_info "Please be patient..."
				sleep .5
				clear
				project_restart "$name"
				break
				;;

			w | wipe)
				_info "Wipe DB: loading..."
				sleep .5
				if ! _project_has_db "$name"; then
					_warn "This project has no database."
					continue
				else
					clear
					project_wipedb "$name"
					break
				fi
				;;

			d | delete)
				_info "Opening delete menu..."
				sleep .5
				clear
				project_delete "$name"
				return 0
				;;

			h | help)
				_info "Opening help..."
				sleep .5
				clear
				help
				_presskey
				break
				;;

			b | back)
				_back
				return 0
				;;
				
			q | quit | e | x | exit) _exit ;;

			*) _error "Invalid choice: '$choice'" ;;
			esac
		done
	done
}

