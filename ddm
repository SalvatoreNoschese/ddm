# Stops all currently running DDEV projects after user confirmation.
stop_all() {
	local projects_raw=""
	local -a running_names=()
	projects_raw="$(_get_ddev_projects)"
	_printbox "$Y" "Stop All Running Projects"
	_warn "This will stop all running DDEV projects."
	_nl
	while IFS='|' read -r name status _type _location; do
		if [[ "$status" == "running" ]]; then
			running_names+=("$name")
			printf "%s\n" "${G}*${NC} $name"
		fi
	done <<<"$projects_raw"
	_nl
	if (( ${#running_names[@]} == 0 )); then
		_info "No running projects found."
		sleep .5
		return 0
	fi
	if ! _prompt_yes_no "Proceed?" "Y"; then
		_warn "Cancelled by user"
		sleep .5
		return 0
	fi
	_nl
	_info "Please be patient..."
	if ddev stop "${running_names[@]}"; then
		_invalidate_ddev_cache
		_done "All running projects stopped"
		_presskey
	else
		_error "ddev stop failed (Is Docker running?)"
		_info "Check status with: ddev list"
		_presskey
		return 1
	fi
}

