# ======================== #

# Returns the configured workspace path from ddm.conf, expanding ~ if needed.
_get_workspace_path() {
	local path=""
	path="$(_conf_get workspace 2>/dev/null || true)"
	path="${path/#\~/$HOME}"
	path="${path%/}"
	echo "${path:-not set}"
}

# Validates that a path is safe for DDM workspace operations.
# Allows: $HOME/*, /mnt/*, /media/*
# Blocks: /, /root, /home, /etc, /usr, /var, and other system directories.
_validate_ddev_path() {
	local path="$1"
	path="${path/#\~/$HOME}"

	local dangerous_paths=("/" "/root" "/home" "/etc" "/usr" "/var" "/opt" "/bin" "/sbin" "/lib" "/lib64" "/boot" "/sys" "/proc" "/dev")
	for dangerous in "${dangerous_paths[@]}"; do
		if [[ "$path" == "$dangerous" ]]; then
			_error "Dangerous path detected: $path"
			_error "This path is not allowed for DDM workspace"
			return 1
		fi
	done

	if [[ "$path" != "$HOME/"* && "$path" != "/mnt/"* && "$path" != "/media/"* ]]; then
		_error "Path must be inside HOME, /mnt, or /media: $path"
		return 1
	fi
	return 0
}

# Installs src to DDM_BIN atomically (install -m 755) and prints feedback.
# Usage: _install_ddm <src> <label>
#   src   — path of the file to install
#   label — past-tense verb shown in the success line (e.g. "Installed", "Replaced", "Updated")
_install_ddm() {
	local src="$1" label="$2"
	install -m 755 "$src" "$DDM_BIN"
	_done "$label: '~/.local/bin/ddm'"
}

# ============================================== #
# SYSTEM CHECK: runs once at every ddm launch    #
# Order: updates > platform guards > PATH/copy   #     
# > deps > docker > ddev > workspace > telemetry #
# ============================================== #
check_system() {
	local default_path="$HOME/ddev-projects"
	mkdir -p "$DDM_CONFIG_DIR"

	# PLATFORM GUARDS
	# Hard exits for unsupported environments.

	# Require Bash 4.3+ (local -n nameref, used by _parse_type_entry).
	if (( BASH_VERSINFO[0] < 4 || ( BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] < 3 ) )); then
		printf '[✗] Bash 4.3 or newer is required (current: %s)\n' "$BASH_VERSION" >&2
		printf '    Please upgrade Bash and re-run ddm.\n' >&2
		exit 1
	fi

	# Termux is not supported (lacks a full Linux container runtime).
	if [[ -n "${TERMUX_VERSION:-}" ]] || [[ -d "/data/data/com.termux" ]]; then
		_error "Termux is not supported"
		_info "DDEV requires a full Linux environment (desktop/server Linux)."
		_say "$B" "DDEV isn't reliably installable on Termux, so Termux isn't supported."
		exit 1
	fi

	# macOS is not supported yet.
	if [[ "$(uname)" == "Darwin" ]]; then
		_error "macOS is not supported yet."
		_info "ddm currently supports Linux only."
		_say "$B" "I can't test it on macOS, so I can't support it."
		exit 1
	fi

	# PATH & INSTALL
	# Only relevant when running from outside ~/.local/bin/ddm.
	local script_path script_name
	script_path="$(realpath "$0")"
	script_name="$(basename "$script_path")"

	# Auto-heal: if install_skip was set but the user has since manually
	# installed ddm (DDM_BIN exists and PATH is configured), the flag is
	# obsolete — remove it silently so updates and menus work normally.
	if [[ -n "$(_conf_get install_skip)" ]] && [[ -f "$DDM_BIN" ]]; then
		local _path_ok=false
		[[ ":$PATH:" == *":$HOME/.local/bin:"* ]] && _path_ok=true
		if [[ "$_path_ok" == false ]]; then
			for _f in "$HOME/.bashrc" "$HOME/.zshrc"; do
				grep -qE "^[^#]*[$]HOME/.local/bin" "$_f" 2>/dev/null && _path_ok=true && break
			done
		fi
		if [[ "$_path_ok" == true ]]; then
			_conf_set "install_skip" ""
		fi
	fi

	if [[ "$script_path" != "$DDM_BIN" ]] && [[ -z "$(_conf_get install_skip)" ]]; then

		# Detect shell rc files
		local rc_files=()
		[[ -f "$HOME/.bashrc" ]] && rc_files+=("$HOME/.bashrc")
		[[ -f "$HOME/.zshrc"  ]] && rc_files+=("$HOME/.zshrc")

		# Check PATH
		local path_in_rc=false need_path=false
		for f in "${rc_files[@]}"; do
			grep -qE "^[^#]*[$]HOME/.local/bin" "$f" 2>/dev/null && path_in_rc=true && break
		done
		[[ ":$PATH:" != *":$HOME/.local/bin:"* ]] && ! $path_in_rc && need_path=true

		# Check file
		local need_copy=false need_replace=false hash_existing="" hash_current=""
		if [[ ! -f "$DDM_BIN" ]]; then
			need_copy=true
		else
			hash_existing="$(md5sum "$DDM_BIN" 2>/dev/null | cut -d' ' -f1)"
			hash_current="$(md5sum "$script_path" 2>/dev/null | cut -d' ' -f1)"
			[[ "$hash_existing" != "$hash_current" ]] && need_replace=true
		fi

		# Shows file diff info and prompts to replace DDM_BIN with script_path.
		# Uses hash_existing/hash_current/script_name from the enclosing scope.
		_offer_replace() {
			local existing_date existing_size current_date current_size
			existing_date="$(date -r "$DDM_BIN"    "+%Y-%m-%d %H:%M" 2>/dev/null || echo "unknown")"
			existing_size="$(du -h "$DDM_BIN"       2>/dev/null | cut -f1 || echo "unknown")"
			current_date="$(date -r "$script_path"  "+%Y-%m-%d %H:%M" 2>/dev/null || echo "unknown")"
			current_size="$(du -h "$script_path"    2>/dev/null | cut -f1 || echo "unknown")"
			_nl
			_warn "ddm in '~/.local/bin' differs from this file."
			_say "" "Installed : $existing_date  $existing_size  $(basename "$DDM_BIN")"
			_say "" "md5       : $hash_existing"
			_say "" "This file : $current_date  $current_size  $script_name"
			_say "" "md5       : $hash_current"
			_nl
			if _prompt_yes_no "Replace installed file with '$script_name'?" "Y"; then
				_install_ddm "$script_path" "Replaced"
				_info "File '~/.local/bin/ddm' is up to date."
				_say "$B" "Next launch will use the new version."
				return 0
			fi
			return 1
		}

		# ── Case 1: PATH or file missing > setup (skippable) ──
		if $need_path || $need_copy; then
			clear
			_printbox "$Y" "PATH Setup"
			if $need_path; then
				_warn "\$HOME/.local/bin is not in your PATH."
				if ((${#rc_files[@]})); then
					local _rc_label=""
					for f in "${rc_files[@]}"; do
						_rc_label+="${_rc_label:+ + }$(basename "$f")"
					done
					_say "$B" "Will add to: \$HOME/$_rc_label"
				else
					_say "$B" "No shell config found — add manually."
				fi
			else
				_done "PATH is already set."
			fi
			if $need_copy; then
				_warn "ddm is not installed in ~/.local/bin."
				_say "$B" "Will install: $script_name → ~/.local/bin/ddm"
			fi
			if _prompt_yes_no "Proceed?" "Y"; then
				if $need_path && ((${#rc_files[@]})); then
					local path_line="# added by ddm\nexport PATH=\"\$HOME/.local/bin:\$PATH\""
					for f in "${rc_files[@]}"; do
						if ! grep -qE "^[^#]*[$]HOME/.local/bin" "$f" 2>/dev/null; then
							printf '%b\n' "$path_line" >> "$f"
							_done "Updated $f"
						fi
					done
				fi
				if $need_copy; then
					_nl
					mkdir -p "$HOME/.local/bin"
					_install_ddm "$script_path" "Installed"
				elif $need_replace; then
					_offer_replace
				fi
				
				if $need_path; then
					_nl
					_info "To apply changes, run one of:"
					_say "$G" "source ~/.bashrc   (or ~/.zshrc)"
					_say "$B" "Or open a new terminal — then run: ddm"
				fi
			else
				_conf_set "install_skip" "true"
				_info "Skipped. To be asked again, run:"
				_say "$Y" "$script_path -r"
			fi
			_presskey "continue"

		# ── Case 2: PATH ok + file different > offer update ──
		elif $need_replace; then
			_offer_replace
			_presskey "continue"
			# Silent: main if rejected

		# ── Case 3: everything ok ──
		fi
	fi

	# Auto update check (non-blocking, throttled to UPDATE_INTERVAL).
	# Requires DDM_BIN and PATH — without both, update has no valid target.
	if [[ -f "$DDM_BIN" ]] && [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]; then
		check_updates
	fi

	# DEPENDENCIES: Detect package manager and install any missing CLI tools.
	local pkg_mgr="" pm_name=""
	local -a pm_update=() pm_install=() required=(jq curl grep awk unzip column) missing_cmds=() missing_pkgs=()

	if command -v pacman >/dev/null 2>&1; then
		pkg_mgr="pacman"
	elif command -v apt >/dev/null 2>&1; then
		pkg_mgr="apt"
	elif command -v dnf >/dev/null 2>&1; then
		pkg_mgr="dnf"
	elif command -v zypper >/dev/null 2>&1; then
		pkg_mgr="zypper"
	fi

	case "$pkg_mgr" in
	pacman)
		pm_name="pacman"
		pm_install=(sudo pacman -Syu --needed)
		;;
	apt)
		pm_name="apt"
		pm_update=(sudo apt update)
		pm_install=(sudo apt install -y)
		;;
	dnf)
		pm_name="dnf"
		pm_install=(sudo dnf install -y)
		;;
	zypper)
		pm_name="zypper"
		pm_install=(sudo zypper install -y)
		;;
	*)
		pm_name=""
		;;
	esac

	_die_say() { _error "$1"; shift; _say "$@"; exit 1; }

	_install_pkgs() {
		local question="$1"; shift
		local -a pkgs=("$@")
		if ((${#pm_update[@]})); then
			_say "$Y" "${pm_update[*]}"
		fi
		_say "$Y" "${pm_install[*]} ${pkgs[*]}"
		_nl
		if ! _prompt_yes_no "$question" "Y"; then
			_info "Run the command above to install manually."
			exit 1
		fi
		if ((${#pm_update[@]})); then
			_info "Updating package index..."
			"${pm_update[@]}" || _die_say "Update failed" "${pm_update[@]}"
			_nl
		fi
		_info "Installing: ${pkgs[*]}"
		"${pm_install[@]}" "${pkgs[@]}" || _die_say "Installation failed" "${pm_install[@]}" "${pkgs[@]}"
		_done "Done."
	}

	for c in "${required[@]}"; do
		command -v "$c" >/dev/null 2>&1 || {
			missing_cmds+=("$c")
			case "$c" in
			awk)    missing_pkgs+=("gawk") ;;
			column) missing_pkgs+=("util-linux") ;;
			*)      missing_pkgs+=("$c") ;;
			esac
		}
	done

	if ((${#missing_cmds[@]})); then
		clear
		_printbox "$R" "Missing required tool(s): ${missing_cmds[*]}"
		if [[ -z "$pkg_mgr" ]]; then
			_info "Cannot detect a supported package manager."
			_info "Install these packages manually, then re-run:"
			printf "%s\n" "  Suggested packages: ${missing_pkgs[*]}"
			exit 1
		fi
		_info "Detected package manager: ${pm_name}"
		_install_pkgs "Install missing tools now?" "${missing_pkgs[@]}"
		_presskey "continue"
	fi

	# DOCKER: Install if missing, then verify the daemon is accessible.
	if ! command -v docker >/dev/null 2>&1; then
		clear
		_printbox "$R" "Docker is not installed (required)"
		if [[ -z "$pkg_mgr" ]]; then
			_error "Cannot detect package manager"
			_info "Install Docker manually from: ${DOCKER_DOCS_URL}"
			exit 1
		fi
		if [[ "$pkg_mgr" == "pacman" ]]; then
			_info "Docker Installation - ${Y}(Arch/Manjaro)${NC}"
			_say "$B" "Packages: docker docker-compose docker-buildx"
			_install_pkgs "Install Docker now?" docker docker-compose docker-buildx
		else
			_info "Installing via Docker convenience script."
			_say "$Y" "$DOCKER_INSTCMD"
			_nl
			if ! _prompt_yes_no "Install Docker now?" "Y"; then
				_warn "Docker installation cancelled"
				_say "" "${DOCKER_DOCS_URL}"
				exit 1
			fi
			if ! (curl -fsSL "$DOCKER_INSTURL" -o get-docker.sh && sudo sh get-docker.sh); then
				rm -f get-docker.sh
				_error "Installation failed"
				exit 1
			fi
			rm -f get-docker.sh
			_done "Docker installed!"
		fi
		_presskey "continue"
	fi

	# If Docker is not accessible, enable the service and add the user to the docker
	# group in a single pass, then prompt for session restart to apply both changes.
	if ! docker ps >/dev/null 2>&1; then
		clear
		_printbox "$R" "Docker is not accessible for: ${USER:-unknown}"
		if command -v sudo >/dev/null 2>&1 && [[ -n "${USER:-}" ]]; then
			_info "The following commands will be executed:"
			_say "$Y" "sudo systemctl enable --now docker"
			_say "$Y" "sudo usermod -aG docker $USER"
			_nl
			if _prompt_yes_no "Enable Docker service and add '$USER' to the docker group now?" "Y"; then
				sudo systemctl enable --now docker >/dev/null 2>&1 || _warn "Could not enable Docker service. Try manually: sudo systemctl enable --now docker"
				if sudo usermod -aG docker "$USER"; then
					_done "Docker service enabled and user '$USER' added to the docker group."
				else
					_error "Failed to add user to docker group. Run manually: sudo usermod -aG docker ${USER}"
				fi
				_nl
				if _prompt_yes_no "Apply changes now with 'newgrp docker' (recommended)?" "Y"; then
					exec newgrp docker
				else
					_info "Log out or reboot, then re-run ddm."
				fi
			else
				_info "Run the commands above manually, then re-run ddm."
			fi
		fi
		exit 1
	fi

	# DDEV: Install if missing
	if ! command -v ddev >/dev/null 2>&1; then
		clear
		_printbox "$R" "DDEV is not installed (required)"
		_info "Install via DDEV install script."
		_say "$Y" "$DDEV_INSTCMD"
		_nl
		if command -v yay >/dev/null 2>&1; then
			_info "Arch hint: yay -S ddev-bin"
		elif command -v paru >/dev/null 2>&1; then
			_info "Arch hint: paru -S ddev-bin"
		fi
		if ! _prompt_yes_no "Install via install script?" "Y"; then
			_warn "DDEV installation cancelled"
			_say "" "${DDEV_DOCS_URL}"
			exit 1
		fi
		_info "Installing DDEV..."
		_nl
		if (set -o pipefail; curl -fsSL "$DDEV_INSTURL" | bash); then
			_done "DDEV installed successfully!"
			_presskey "continue"
		else
			_error "DDEV installation failed"
			exit 1
		fi
	fi

	# WORKSPACE
	# Configure projects directory on first run.
	# On Android, enforce a fixed safe path.
	if [[ -z "$(_conf_get workspace)" ]]; then
		clear
		_printbox "$Y" "Workspace Setup"
		_info "This will only appear once."
		_nl
		if _is_android; then
			_warn "Android environment detected."
			_info "For stability, ddm uses a fixed workspace inside HOME:"
			_say "" "$default_path"
			mkdir -p "$default_path"
			_conf_set "workspace" "$default_path"
			_done "Workspace set and ready."
		else
			local input_path=""
			while true; do
				read -r -p "Enter DDEV projects directory [$default_path]: " input_path
				input_path="${input_path:-$default_path}"
				input_path="${input_path/#\~/$HOME}"
				if _validate_ddev_path "$input_path"; then break; fi
				_nl; _error "Please choose a safe path"; _nl
			done
			mkdir -p "$input_path"
			_conf_set "workspace" "$input_path"
			_done "Workspace set to: $input_path"
		fi
		_presskey "continue"
	fi

	# Android only: if config exists but points to a non-allowed path, force reset.
	if _is_android; then
		local configured=""
		configured="$(_conf_get workspace 2>/dev/null || true)"
		configured="${configured/#\~/$HOME}"
		if [[ "$configured" != "$default_path" ]]; then
			clear
			_printbox "$R" "Android Workspace Reset"
			_error "Android environment: custom workspace paths are disabled."
			_nl
			_info "Configured path:"; _say "$Y" "$configured"; _nl
			_info "Allowed path (fixed for stability):"; _say "$G" "$default_path"; _nl
			_warn "Reason: shared mounts (e.g. /mnt/shared)"
			_say "$B" "may cause crashes or file permission issues."
			_nl
			if _prompt_yes_no "Rewrite workspace to the allowed path now?" "Y"; then
				_conf_set "workspace" "$default_path"
				_done "Workspace reset to: $default_path"
				_presskey "continue"
			else
				exit 1
			fi
		fi
	fi

	DDEV_DIR="$(_get_workspace_path)"
	if ! _validate_ddev_path "$DDEV_DIR"; then
		_error "Configured path is not safe: $DDEV_DIR"
		_error "Please reset with: ddm -r"
		exit 1
	fi
	if [[ ! -d "$DDEV_DIR" ]]; then
		mkdir -p "$DDEV_DIR" || { _error "Failed to create $DDEV_DIR. Check permissions."; exit 1; }
	fi

	# TELEMETRY: Ask once on first run whether to enable DDEV telemetry.
	if [[ -z "$(_conf_get telemetry)" ]]; then
		clear
		_printbox "$Y" "DDEV Telemetry"
		_info "This will only appear once."
		_nl
		_info "DDEV collects anonymous usage data to improve the project."
		_say "$B" "https://ddev.com/privacy-policy/"
		_nl
		if _prompt_yes_no "Enable DDEV telemetry?" "Y"; then
			ddev config global --instrumentation-opt-in=true >/dev/null 2>&1
			_conf_set "telemetry" "true"
			_done "Telemetry enabled."
		else
			ddev config global --instrumentation-opt-in=false >/dev/null 2>&1
			_conf_set "telemetry" "false"
			_done "Telemetry disabled."
		fi
		_presskey "start ddm"
	fi
}

# ==================== #
# PROJECT TYPE HELPERS #
# ==================== #

# Generic field resolver from PROJECT_TYPES by project name prefix.
# Usage: _type_field_from_prefix "<name>" "<field>"
# Valid fields: key | label | prefix | cat | admin
# Falls back to the raw prefix for "label" when not found; empty for all others.
_type_field_from_prefix() {
	local name="$1" field="$2" entry
	local prefix="${name%%-*}"
	local -A t
	for entry in "${PROJECT_TYPES[@]}"; do
		_parse_type_entry "$entry" t
		if [[ "${t[prefix]}" == "$prefix" ]]; then
			echo "${t[$field]:-}"
			return 0
		fi
	done
	[[ "$field" == "label" ]] && echo "$prefix"
}

# Resolves the display label for a project from its name prefix.
# Usage: label=$(_type_label_from_prefix "wp-mysite")  -->  "WordPress"
_type_label_from_prefix() { _type_field_from_prefix "$1" "label"; }

# Resolves the admin URL path for a project from its name prefix.
# Returns empty string if no admin path is defined.
# Usage: path=$(_get_admin_path "wp-mysite")  -->  "/wp-admin"
_get_admin_path() { _type_field_from_prefix "$1" "admin"; }

# ============ #
# DDEV QUERIES #
# ============ #

# Cache 'ddev list --json-output' during a single menu render to avoid repeated calls.
# Call _invalidate_ddev_cache() after actions that change project state.
_DDEV_LIST_CACHE=""

_invalidate_ddev_cache() {
	_DDEV_LIST_CACHE=""
}

# Returns the cached JSON output of 'ddev list', fetching it on first call.
_ddev_list_json() {
	if [[ -z "$_DDEV_LIST_CACHE" ]]; then
		_DDEV_LIST_CACHE="$(ddev list --json-output 2>/dev/null || true)"
	fi
	printf "%s\n" "$_DDEV_LIST_CACHE"
}

# Returns a pipe-delimited list of all DDEV projects: name|status|type|path
_get_ddev_projects() {
	_ddev_list_json |
		jq -r '
			(if (.raw | type) == "array" then .raw else (.[] // []) end) // []
			| .[]
			| [
				.name // "",
				.status // "",
				(.type // .project_type // .apptype // ""),
				(.approot // .location // .path // "")
			] | @tsv
		' |
		awk -F'\t' 'NF == 4 && $1 != "" { print $1 "|" $2 "|" $3 "|" $4 }' ||
		true
}

# Returns 0 if at least one project in the given raw list is running.
# Usage: _has_running_projects "$projects_raw"
_has_running_projects() {
	local projects_raw="$1"
	[[ -z "$projects_raw" ]] && return 1
	printf '%s\n' "$projects_raw" | grep -q "|running|"
}

# Returns the status string for a single project (e.g. "running", "stopped").
_get_project_status() {
	local name="$1"
	_ddev_list_json |
		jq -r --arg n "$name" '(.raw // .)[] | select(.name == $n) | .status // ""' 2>/dev/null ||
		true
}

# Returns the filesystem path of the project root directory.
_get_project_path() {
	local name="$1"
	_ddev_list_json |
		jq -r --arg n "$name" \
			'(.raw // .)[] | select(.name == $n) | .approot // .location // .path // ""' \
			2>/dev/null ||
		true
}

# Returns 0 if the project has a database container configured.
# Checks .ddev/config.yaml: if "- db" appears in any list (typically omit_containers), returns 1.
# Defaults to true (all project types in this tool include a DB unless explicitly omitted).
_project_has_db() {
	local name="$1"
	local path=""
	path="$(_get_project_path "$name")"
	[[ -z "$path" ]] && return 1
	local config="$path/.ddev/config.yaml"
	[[ ! -f "$config" ]] && return 0 # Config not found; assume DB present.
	# If "- db" is listed in any YAML list, assume no database.
	if grep -qE '^[[:space:]]*-[[:space:]]*db([[:space:]]|$)' "$config" 2>/dev/null; then
		return 1
	fi
	return 0
}

# =============== #
# PROJECT DISPLAY #
# =============== #

# Prints the project primary URL, admin URL (from registry), and add-on URLs.
# Note: calls 'ddev describe' directly rather than the list cache because
# describe returns richer data (service URLs, endpoints) not in ddev list.
_show_project_urls() {
	local name="$1"
	local project_json="" data="" admin_path="" primary_url="" pma_url="" adminer_url="" mailpit_url=""

	project_json="$(ddev describe "$name" -j 2>/dev/null)"

	if [[ -z "$project_json" ]] || [[ "$project_json" == "null" ]]; then
		_error "Could not retrieve info for: $name"
		return 1
	fi

	data="$(printf '%s\n' "$project_json" | jq -r '
		[
			(.raw.primary_endpoint // .primary_endpoint),
			(.raw.services.phpmyadmin.https_url // .raw.services.phpmyadmin.http_url),
			(.raw.services.adminer.https_url // .raw.services.adminer.http_url),
			(.raw.services.mailpit.https_url // .raw.services.mailpit.http_url)
		] | map(select(. != null) // "") | join("|")
	')"

	IFS='|' read -r primary_url pma_url adminer_url mailpit_url <<<"$data"

	printf "%s\n\n" "${B}URLs ($name):${NC}"

	[[ -z "$primary_url" ]] && primary_url="https://$name.ddev.site"
	_info "Home:"
	_say "$B" "${B}$primary_url${NC}"

	admin_path="$(_get_admin_path "$name")"

	# PrestaShop uses a randomized admin folder name — detect it dynamically.
	local prefix="${name%%-*}"
	if [[ "$prefix" == "ps" && -n "$admin_path" ]]; then
		local project_root="$DDEV_DIR/$name"
		local real_admin=""
		real_admin="$(find "$project_root" -maxdepth 1 -type d -name 'admin*' 2>/dev/null | head -1)"
		if [[ -n "$real_admin" ]]; then
			admin_path="/${real_admin##*/}"
		else
			admin_path=""
			_info "Admin (run browser setup first):"
			_say "$B" "${B}Visit Home URL to complete installation.${NC}"
		fi
	fi
	if [[ -n "$admin_path" ]]; then
		_info "Admin:"
		_say "$B" "${B}${primary_url}${admin_path}${NC}"
	fi

	[[ -n "$pma_url" ]] && {
		_info "PMA(db):"
		_say "" "${B}${pma_url}${NC}"
	}
	[[ -n "$adminer_url" ]] && {
		_info "Adminer:"
		_say "" "${B}${adminer_url}${NC}"
	}
	[[ -n "$mailpit_url" ]] && {
		_info "Mailpit:"
		_say "" "${B}${mailpit_url}${NC}"
	}
}

# ===================== #
# PROJECT SETUP HELPERS #
# ===================== #

# Creates the project directory under DDEV_DIR and changes into it.
# Called first by every install_* function.
_setup_project_dir() {
	local name="$1"
	local project_path="$DDEV_DIR/$name"
	_info "Creating project directory: $project_path"
	mkdir -p "$project_path" || {
		_error "Cannot create directory"
		return 1
	}
	cd "$project_path" || {
		_error "Cannot access directory"
		return 1
	}
	_done "Project directory ready"
}

# Starts DDEV and reports failure with a consistent message.
# Usage: _ddev_start || return 1
_ddev_start() {
	ddev start -y || {
		_error "DDEV start failed"
		return 1
	}
}

# ============== #
# PROJECT GUARDS #
# ============== #

# Ensures a project is running before performing an action that requires it.
# Offers to start the project if it is currently stopped.
#
# Return codes:
#   0 - project was already running
#   2 - project was just started by this function
#   1 - user declined to start, or start failed
_ensure_running() {
	local name="$1"
	local status
	status="$(_get_project_status "$name")"

	if [[ "$status" == "running" ]]; then
		return 0
	fi

	_say "$Y" "Project is not running (status: ${Y}$status${NC})"
	if _prompt_yes_no " ${G}>${NC}  Start $name now?" "Y"; then
		if project_start "$name"; then
			return 2
		fi
		clear
	else
		_say "" "Aborted by user..."
		sleep 1
	fi
	return 1
}

# =============== #
# PROJECT ACTIONS #
# =============== #

# Runs 'ddev describe' and waits for a keypress before returning.
project_describe() {
	local name="$1"
	_printbox "$C" "ddev describe for $name"
	ddev describe "$name"
	_presskey "return"
}

# Starts a stopped project. No-ops silently if already running.
project_start() {
	local name="$1"

	_printbox "$G" "Start: $name"
	_info "Please be patient..."
	_say "$G" "ddev start $name"
	_nl

	if ddev start "$name"; then
		_invalidate_ddev_cache
		_done "Started: $name"
		_presskey
		return 0
	fi

	_error "Start failed: $name"
	_troubleshoot
	_presskey
	return 1
}

# Stops a running project. No-ops silently if already stopped.
project_stop() {
	local name="$1"
	_printbox "$Y" "Stop: $name"
	_info "Please be patient..."
	_say "$Y" "ddev stop $name"
	_nl

	if ddev stop "$name"; then
		_invalidate_ddev_cache
		_done "Stopped: $name"
		_presskey
		return 0
	fi

	_error "Stop failed: $name"
	_presskey
	return 1
}

# Restarts a project, starting it first if necessary.
project_restart() {
	local name="$1"
	local res
	_ensure_running "$name"
	res=$?
	[[ $res -eq 1 ]] && return 1 # User declined or start failed.
	[[ $res -eq 2 ]] && return 0 # Project was just started; restart not needed.
	_printbox "$Y" "Restart: $name"
	_info "Please be patient..."
	_say "$Y" "ddev restart $name"
	_nl
	if ddev restart "$name"; then
		_invalidate_ddev_cache
		_done "Restarted: $name"
		_presskey
		return 0
	fi

	_error "Restart failed: $name"
	_presskey
	return 1
}

# Opens the project in the default browser via 'ddev launch'.
# Starts the project first if it is not running.
project_open() {
	local name="$1"
	local path res
	_nl
	path="$(_get_project_path "$name")"
	[[ -z "$path" ]] && {
		_error "Project not found: $name"
		return 1
	}
	_ensure_running "$name"
	res=$?
	[[ $res -eq 1 ]] && return 1 # User declined or start failed.
	cd "$path" || {
		_error "Cannot access: $path"
		return 1
	}

	_info "Launching browser for: $name"
	if ddev launch 2>/dev/null; then
		return 0
	fi
	_warn "Browser launch failed (ddev launch error)"
	return 1
}

# Opens an SSH terminal inside the project web container.
project_ssh() {
	local name="$1"
	local res
	_ensure_running "$name"
	res=$?
	[[ $res -eq 1 ]] && return 1 # User declined or start failed.
	clear
	_printbox "$C" "Opening terminal for: $name..."
	_info "Type exit when finished..."
	ddev ssh "$name"
	clear # Clean up output on exit.
}

# Drops and recreates the project database after explicit typed confirmation.
# If the project is stopped, starts it temporarily for database access,
# then restores the stopped state afterward.
project_wipedb() {
	local name="$1"
	local path="" status wipe_label
	local started_by_us=0
	status="$(_get_project_status "$name")"

	path="$(_get_project_path "$name")"
	[[ -z "$path" ]] && {
		_error "Project not found: $name"
		return 1
	}

	wipe_label="$(_type_label_from_prefix "$name")"

	clear
	_printbox "$R" "WIPE DATABASE: $name${wipe_label:+ ($wipe_label)}"
	_warn "This will PERMANENTLY delete all data in the database."
	_warn "Configuration and files will not be touched."
	_nl

	if ! _prompt_yes_no "Wipe database for '$name'?" "N"; then
		_info "Wipe database aborted..."
		sleep 1
		return 1
	fi

	if [[ "$status" != "running" ]]; then
		_info "Project is not running (status: $status), starting temporarily..."
		ddev start "$name" &>/dev/null || {
			_error "Could not start DDEV for database access"
			return 1
		}
		started_by_us=1
	fi

	cd "$path" || {
		_error "Cannot access: $path"
		return 1
	}

	_info "Wiping database..."
	if ddev mysql -e "DROP DATABASE IF EXISTS db; CREATE DATABASE db;"; then
		_invalidate_ddev_cache
		_done "Database for '$name' has been wiped!"
		_presskey
	else
		_error "Database wipe failed."
		_presskey
		return 1
	fi

	if [[ $started_by_us -eq 1 ]]; then
		_info "Stopping project (was not running before)..."
		ddev stop "$name" &>/dev/null
	fi
}

# Removes a project from the DDEV registry (project directory is preserved).
# Supports single-project and bulk ("DELETE_ALL_PROJECTS") modes.
# Offers a choice between saving or discarding DDEV snapshots.
project_delete() {
	local target="${1:-}"
	local display_name="$target" display_label="" path="" status choice="" snapshot_msg=""
	local is_bulk=false
	# Declare as local to prevent state leaking across repeated calls
	# (extra_flags must not accumulate --omit-snapshot between invocations).
	local -a extra_flags=()


	if [[ "$target" == "DELETE_ALL_PROJECTS" ]]; then
		is_bulk=true
		display_name="ALL PROJECTS"
	else
		status="$(_get_project_status "$target")"
		if [[ -z "$status" ]]; then
			_error "Project not found: $target"
			return 1
		fi
		display_label="$(_type_label_from_prefix "$target")"
		display_name="$target${display_label:+ ($display_label)}"
	fi

	_printbox "$R" "DELETE: $display_name"

	if [[ "$is_bulk" == true ]]; then
		_warn "All projects will be removed from registry!"
		_info "Project directories are NOT deleted:"
		_info "To remove directories, use file manager or:"
		_nl

		_ddev_list_json 2>/dev/null |
			jq -r '(.raw // .)[] | "\(.name)|\(.approot // .location // .path // "")"' 2>/dev/null |
			while IFS='|' read -r name path; do
				[[ -z "$name" ]] && continue

				local label display_name
				label="$(_type_label_from_prefix "$name")"
				display_name="$name${label:+ ($label)}"

				printf "%s\n" " *  ${G}${display_name}${NC}"

				if [[ -z "$path" ]]; then
					_warn "Path not found for: $display_name"
					continue
				fi
				_say "" "${R}rm -rf \"$path\"${NC}"
			done
	else
		_warn "${target} will be removed only from registry!"
		_info "The project directory is NOT deleted:"
		_info "To remove directory, use file manager or:"

		printf "\n%s\n" " *  ${G}${display_name}${NC}"

		path="$(_get_project_path "$target")"
		if [[ -z "$path" ]]; then
			_warn "Path not found for: $display_name"
		else
			_say "" "${R}rm -rf \"$path\"${NC}"
		fi
	fi

	printf "\n%s\n" "Select deletion mode:"
	printf "%s\n" "${Y}[1]${NC} Delete (SAVE snapshots)"
	printf "%s\n\n" "${R}[2]${NC} Delete (OMIT snapshots - faster, data lost)"
	printf "%s\n\n" "${M}[b]${NC}ack  [e]xit"
	_nl

	while true; do
		choice="$(_read_input "Selection")"
		case "$choice" in
		1)
			snapshot_msg="${G}Snapshots will be saved.${NC}"
			break
			;;
		2)
			extra_flags+=(--omit-snapshot)
			snapshot_msg="${R}NO snapshots saved (data permanently lost).${NC}"
			break
			;;
		b | back)
			_back
			return 0
			;;
		q | quit | e | x | exit)
			_exit
			;;
		*)
			_error "Invalid selection. Try again."
			;;
		esac
	done

	printf "\n%s\n" "Mode: $snapshot_msg"

	if [[ "$is_bulk" == true ]]; then
		_nl
		if ! _prompt_yes_no "Are you ABSOLUTELY sure?" "N"; then
			_info "Deletion cancelled."
			sleep 1
			return 0
		fi

		_info "Executing: ddev delete --all ${extra_flags[*]}"
		_nl
		if ddev delete --all "${extra_flags[@]}"; then
			_invalidate_ddev_cache
			_done "All projects removed from DDEV registry."
			_presskey "return"
		else
			_error "An error occurred during bulk deletion."
			_presskey "return"
			return 1
		fi
	else
		if ! _prompt_yes_no "Are you ABSOLUTELY sure you want to proceed?" "N"; then
			_info "Deletion cancelled."
			sleep 1
			return 0
		fi

		_info "Executing deletion..."
		if ddev delete "$target" -y "${extra_flags[@]}"; then
			_invalidate_ddev_cache
			_done "Project '$target' deleted."
			_presskey
		else
			_error "An error occurred deleting '$target'."
			_presskey
			return 1
		fi
	fi
}

# Troubleshooting hints after failure
_troubleshoot() {
	_warn "Common fixes (depending on the message above):"
	_say "$B" "If you see DNS/resolve/timeout errors: check /etc/resolv.conf or your network DNS (e.g. 1.1.1.1 / 8.8.8.8)."
	_say "$B" "If you see bridge/veth errors: sudo modprobe bridge && sudo modprobe veth"
	_say "$B" "If this started after a kernel update: reboot and retry."
}

