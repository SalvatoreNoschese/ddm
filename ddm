# Displays the tools and maintenance menu.
# Options form an escalation scale: each level includes the previous.
#   [1] Poweroff
#   [2] Poweroff + Docker Cleaner
#   [3] Delete All Projects (if any)
#   [n] Poweroff + Cleaner + Delete All (if any) + full Docker wipe
tools_menu() {
	while true; do
		local projects_raw=""
		projects_raw="$(_get_ddev_projects)"

		local has_projects=false
		local project_count=0
		local nuclear_steps="1 + 2 + full Docker wipe."
		if [[ -n "$projects_raw" ]]; then
			has_projects=true
			project_count="$(echo "$projects_raw" | wc -l)"
			nuclear_steps="1 + 2 + 3 + full Docker wipe."
		fi

		_printbox "$M" "Tools & Maintenance"

		# Disk usage shown automatically for context.
		printf "%s\n" "${C}Docker disk usage:${NC}"
		docker system df 2>/dev/null || _warn "Docker not accessible"
		_nl

		printf "%s\n" "${Y}[1] DDEV Poweroff (no confirm)${NC}"
		_say "$B" "Stops containers, router and SSH agent."
		_nl

		printf "%s\n" "${Y}[2] Poweroff + Docker Cleaner${NC}"
		_say "$B" "1 + Removes unused images and build cache."
		_say "$B" "Projects and databases are safe."
		_nl

		if [[ "$has_projects" == true ]]; then
			printf "%s\n" "${R}[3] Delete All Projects${NC}"
			_say "$B" "Removes $project_count project(s) from DDEV registry."
			_say "$B" "For safety, directories remain on disk."
			_nl
		fi

		printf "%s\n" "${R}[n] Nuclear Reset${NC}"
		_say "$B" "$nuclear_steps"
		_say "$B" "Like reinstalling Docker from scratch."
		_nl

		printf "%s\n" "${M}[b]${NC}ack  [e]xit"
		_nl

		while true; do
			local choice=""
			choice="$(_read_input "Selection")"

			case "$choice" in
			1)
				clear
				_tools_poweroff
				_presskey "return"
				clear
				break
				;;

			2)
				clear
				_printbox "$Y" "Poweroff + Docker Cleaner"
				_info "Poweroff + Removes unused images and cache."
				_info "Projects and databases are NOT affected."
				_nl

				if _prompt_yes_no "Proceed?" "N"; then
					_nl
					_tools_poweroff
					_nl
					_tools_docker_cleaner
					_presskey "return"
				else
					_info "Step 2: Aborted."
					sleep 1
				fi
				clear
				break
				;;

			3)
				if [[ "$has_projects" == true ]]; then
					_info "Opening delete menu..."
					sleep .5
					clear
					project_delete "DELETE_ALL_PROJECTS"
					clear
					break
				else
					_info "Item disabled: No projects available..."
				fi
				;;

			n | nuclear)
				clear
				_printbox "$R" "NUCLEAR RESET"
				_warn "This will DESTROY EVERYTHING:"
				_say "$B" "Poweroff DDEV"
				[[ "$has_projects" == true ]] && _say "$B" "Delete all projects from registry"
				_say "$B" "Wipes all containers, volumes, images, networks"
				_nl
				_warn "This CANNOT be undone."
				_nl

				if _prompt_yes_no "Are you ABSOLUTELY sure?" "N"; then
					local b_space
					b_space="$(docker system df --format "{{.Size}}")"
					_nl
					_tools_poweroff
					_nl

					if [[ "$has_projects" == true ]]; then
						_info "Removing all projects from registry..."
						_say "$Y" "ddev delete --all --omit-snapshot"
						ddev delete --all --omit-snapshot || true
						_invalidate_ddev_cache
					fi
					sleep .5
					_nl

					_tools_docker_cleaner
					_nl

					_tools_docker_wipe

					_done "Nuclear reset complete. Space: $b_space -> $(docker system df --format "{{.Size}}")"
					_presskey "return"
				else
					_info "Nuclear: Aborted..."
					sleep 1
				fi
				clear
				break
				;;

			q | quit | e | x | exit)
				_exit
				;;

			b | back)
				_back
				return 0
				;;
			*) _error "Invalid choice. Try again." ;;
			esac
		done
	done
}

# ============== #
# UPDATE CHECKER #
# ============== #
# Checks for a newer version of ddm on GitHub.
# Automatic mode (force=false): respects UPDATE_INTERVAL throttle, silent on no update.
# Manual mode    (force=true):  always checks and always shows a result.
check_updates() {
	local force="${1:-false}"
	local remote_version="" temp_file="" docker_v=""
	local ddev_installed="" ddev_latest="" ddev_after=""
	local last_check="" now elapsed
	docker_v="$(_docker_version)"
	if [[ "$force" == false ]]; then
		if [[ -f "$UPDATE_FILE" ]]; then
			last_check="$(stat -c %Y "$UPDATE_FILE" 2>/dev/null || stat -f %m "$UPDATE_FILE" 2>/dev/null || echo 0)"
			now="$(date +%s)"
			elapsed=$((now - last_check))
			[[ $elapsed -lt $UPDATE_INTERVAL ]] && return 0
		fi
	fi
	touch "$UPDATE_FILE" 2>/dev/null
	if [[ "$force" == true ]]; then
		_printbox "$M" "$DDM_INFO - Check Updates"
		_info "Checking for updates..."
	fi
	# ── ddm update check ── #
	remote_version="$(curl -fsSL --max-time 3 "$UPDATE_URL" 2>/dev/null | grep '^DDM_VER=' | head -n 1 | cut -d'"' -f2)"
	if [[ -z "$remote_version" ]]; then
		if [[ "$force" == true ]]; then
			_warn "Cannot check ddm updates (network issue?)"
		fi
	else
		if [[ "$remote_version" != "$DDM_VER" ]]; then
			_nl
			_done "New version available: v$remote_version (current: v$DDM_VER)"
			_nl
			if _prompt_yes_no "Update now?" "Y"; then
				_info "Downloading latest version..."
				temp_file="$(mktemp)"
				trap 'rm -f "$temp_file"' RETURN
				if ! curl -fsSL "$UPDATE_URL" -o "$temp_file" || [[ ! -s "$temp_file" ]]; then
					_error "Update failed: network error or empty file received"
				else
					# Only update the canonical install location.
					# If ddm is not installed yet, ask the user to run it
					# interactively first so check_system handles the setup.
					if [[ ! -f "$DDM_BIN" ]]; then
						_warn "ddm is not installed — update skipped."
						_info "Run 'ddm' once (without flags) to install it first."
					else
						_install_ddm "$temp_file" "Updated to v$remote_version"
						_info "Restart ddm to use the new version."
						exit 0
					fi
				fi
			fi
		else
			if [[ "$force" == true ]]; then
				_done "ddm is already up to date (v$DDM_VER)"
			fi
		fi
	fi
	# ── DDEV update check
	ddev_installed="$(_ddev_version)"
	if [[ -n "$ddev_installed" ]]; then
		ddev_latest="$(curl -fsSL --max-time 5 \
			"https://api.github.com/repos/ddev/ddev/releases/latest" 2>/dev/null |
			jq -r '.tag_name // empty')"
		if [[ -n "$ddev_latest" && "$ddev_latest" != "$ddev_installed" ]]; then
			_nl
			_warn "DDEV update available: ${G}${ddev_latest}${NC} (current: ${ddev_installed})"
			_say "$B" "https://docs.ddev.com/en/stable/users/install/ddev-upgrade/"
			_nl
			if _prompt_yes_no "Run 'ddev self-upgrade' now?" "Y"; then
				ddev self-upgrade
				ddev_after="$(_ddev_version)"
				if [[ "$ddev_after" == "$ddev_latest" ]]; then
					_done "DDEV upgraded to ${ddev_latest}!"
				else
					_nl
					_warn "Automatic upgrade not available for your installation method."
					_say "$Y" "$DDEV_INSTCMD"
					_nl
					if _prompt_yes_no "Run the install script now?" "Y"; then
						_nl
						_warn "This will stop all running DDEV projects."
						if ! _prompt_yes_no "Run 'ddev poweroff' and proceed?" "Y"; then
							_info "Upgrade cancelled — run manually:"
							_say "$Y" "$DDEV_INSTCMD"
						else
							_info "Running 'ddev poweroff'..."
							ddev poweroff || true
							_nl
							if (
								set -o pipefail
								curl -fsSL "$DDEV_INSTURL" | bash
							); then
								_done "DDEV upgraded to ${ddev_latest}!"
							else
								_error "Upgrade failed — run manually:"
								_say "$Y" "$DDEV_INSTCMD"
							fi
						fi
					else
						_info "Run manually:"
						_say "$Y" "$DDEV_INSTCMD"
					fi
				fi
			fi
			_presskey
		elif [[ "$force" == true ]]; then
			_done "DDEV is already up to date (${ddev_installed})"
		fi
	fi

	if [[ "$force" == true ]]; then
		_nl
		_info "Docker: ${docker_v:-n/a}"
		_say "$B" "updates are managed by your system package manager."
	fi
}

# ========= #
# MAIN MENU #
# ========= #

# Renders the top-level interactive menu and loops until the user exits or
# selects a project, delegating to manage_project() for project actions.
_main_menu() {
	clear
	_invalidate_ddev_cache

	local choice
	local projects_raw=""
	projects_raw="$(_get_ddev_projects)"

	local -a names=()

	_printbox "$M" "$DDM_INFO"

	if [[ -z "$projects_raw" ]]; then
		printf "%s\n" "${Y}No DDEV projects found"
		printf "\n%s\n" "${M}Actions:${NC}"
		printf "\n%s\n" "${G}[n]${NC}ew-project   ${R}[t]${NC}ools   ${M}[h]${NC}elp   [e]xit"
	else
		printf "%s\n\n" "${B}DDEV Projects:${NC}"

		# Sort projects following PROJECT_TYPES registry order (category + position).
		# Iterates the registry and picks matching projects; unknown prefixes go last.
		local sorted_raw=""
		local _line _prefix _pp
		for entry in "${PROJECT_TYPES[@]}"; do
			IFS=':' read -r _ _ _pp _ _ <<<"$entry"
			while IFS= read -r _line; do
				_prefix="${_line%%|*}"
				_prefix="${_prefix%%-*}"
				[[ "$_prefix" == "$_pp" ]] && sorted_raw+="$_line"$'\n'
			done <<<"$projects_raw"
		done
		# Append any projects whose prefix is not in the registry.
		while IFS= read -r _line; do
			_prefix="${_line%%|*}"
			_prefix="${_prefix%%-*}"
			local _found=0
			for entry in "${PROJECT_TYPES[@]}"; do
				IFS=':' read -r _ _ _pp _ _ <<<"$entry"
				[[ "$_prefix" == "$_pp" ]] && {
					_found=1
					break
				}
			done
			[[ $_found -eq 0 ]] && sorted_raw+="$_line"$'\n'
		done <<<"$projects_raw"
		sorted_raw="${sorted_raw%$'\n'}"
		projects_raw="$sorted_raw"

		local i=0
		local name status _type _location
		local max_name=0 max_type_with_parens=0 total_projects=0

		# First pass: calculate column widths for aligned output.
		while IFS='|' read -r name status _type _location; do
			((total_projects++))
			local display_type
			display_type="$(_type_label_from_prefix "$name")"
			[[ ${#name} -gt $max_name ]] && max_name="${#name}"
			local type_len=$((${#display_type} + 2))
			[[ $type_len -gt $max_type_with_parens ]] && max_type_with_parens="$type_len"
		done <<<"$projects_raw"
		local idx_pad=$((${#total_projects} + 2))

		# Second pass: render the aligned project list with category headers.
		local prev_cat="" display_type cat effective_cat prefix entry
		local pad_name type_with_parens pad_type status_color
		local -A t
		while IFS='|' read -r name status _type _location; do
			display_type="$(_type_label_from_prefix "$name")"
			# Resolve category from registry
			prefix="${name%%-*}"
			cat=""
			for entry in "${PROJECT_TYPES[@]}"; do
				_parse_type_entry "$entry" t
				[[ "${t[prefix]}" == "$prefix" ]] && { cat="${t[cat]}"; break; }
			done
			# Print category header on change
			effective_cat="${cat:-unmanaged}"
			if [[ "$effective_cat" != "$prev_cat" ]]; then
				case "$effective_cat" in
				cms)       printf "%s\n" " ${M}──────────────────── CMS ────────────────────${NC}" ;;
				framework) printf "%s\n" " ${M}───────────────── Framework ─────────────────${NC}" ;;
				extra)     printf "%s\n" " ${M}─────────────────── Extra ───────────────────${NC}" ;;
				unmanaged) printf "%s\n" " ${Y}───────────────── Unmanaged ─────────────────${NC}" ;;
				esac
				prev_cat="$effective_cat"
			fi
			names+=("$name")
			status_color="$Y"
			[[ "$status" == "running" ]] && status_color="$G"

			printf -v pad_name "%-${max_name}s" "$name"
			type_with_parens="($display_type)"
			printf -v pad_type "%-${max_type_with_parens}s" "$type_with_parens"

			printf " ${G}%${idx_pad}s${NC} ${C}${pad_name} ${pad_type}${NC} ${status_color}[${status}]${NC}\n" "$((i + 1))"

			((i++))
		done <<<"$projects_raw"

		printf "\n%s\n\n" "${M}Actions:${NC}"
		local range="[1]"
		[[ ${#names[@]} -gt 1 ]] && range="[1-${#names[@]}]"
		printf "%s\n" " ${C}$range${NC} select-project"
		if _has_running_projects "$projects_raw"; then
			printf "%s\n" " ${G}[n]${NC}ew   ${Y}[s]${NC}top-all   ${R}[t]${NC}ools   ${M}[h]${NC}elp   [e]xit"
		else
			printf "%s\n" " ${G}[n]${NC}ew   ${R}[t]${NC}ools   ${M}[h]${NC}elp   [e]xit"
		fi
	fi
	_nl

	while true; do
		choice="$(_read_input "Choice")"

		case "$choice" in
		n | new)
			_info "Opening Create New Project..."
			sleep .5
			create_project
			return 0
			;;
		t | tools)
			_info "Opening tools menu..."
			sleep .5
			clear
			tools_menu
			return 0
			;;
		u | update)
			# Hidden shortcut: not shown in the menu UI.
			# Requires ddm to be properly installed (DDM_BIN + active PATH).
			if ! _ddm_is_installed; then
				_warn "ddm is not properly installed — see Status in 'ddm -h'."
				sleep 2
			else
				_info "Opening update manager..."
				sleep .5
				clear
				check_updates true
				_presskey
				return 0
			fi
			;;
		h | help)
			_info "Opening help..."
			sleep .5
			clear
			help
			_presskey
			return 0
			;;

		b | back | q | quit | e | x | exit)
			_exit
			;;

		s | stop)
			if [[ -z "$projects_raw" ]]; then
				_warn "No projects found yet."
				continue
			fi
			if ! _has_running_projects "$projects_raw"; then
				_info "No running projects."
				continue
			fi
			_info "Stopping all projects..."
			sleep .5
			clear
			stop_all
			return 0
			;;

		p | poweroff)
			_info "Powering off DDEV..."
			sleep .5
			clear
			_tools_poweroff
			_presskey "return"
			return 0
			;;

		*)
			if [[ -n "$projects_raw" ]] && [[ "$choice" =~ ^[0-9]+$ ]] &&
				[[ "$choice" -ge 1 ]] && [[ "$choice" -le "${#names[@]}" ]]; then
				local selected="${names[$((choice - 1))]}"
				_info "Go to: $selected"
				sleep .5
				manage_project "$selected"
				return 0
			fi
			_error "Invalid choice. Try again."
			;;
		esac
	done
}

