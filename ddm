	_printbox "$Y" "DDEV poweroff"
	ddev poweroff || true
	_invalidate_ddev_cache
	_nl
	_done "DDEV powered off."
}

# Cleans unused Docker images and build cache.
# Projects and databases are NOT affected.
_tools_docker_cleaner() {
	local b_space
	b_space="$(docker system df --format "{{.Size}}")"
	_nl

	_info "Step 1: Cleaning DDEV snapshots..."
	_say "$Y" "ddev snapshot --cleanup --all"
	ddev snapshot --cleanup --all || true
	sleep .5
	_nl

	_info "Step 2: Cleaning DDEV images..."
	_say "$Y" "ddev delete images -y"
	ddev delete images -y || true
	sleep .5
	_nl

	_info "Step 3: Cleaning inactive hostnames..."
	_say "$Y" "ddev hostname --remove-inactive"
	ddev hostname --remove-inactive || true
	sleep .5
	_nl

	_info "Step 4: Docker system prune..."
	_say "$Y" "docker system prune -f"
	docker system prune -f
	sleep .5
	_nl

	_done "Done! Space freed: $b_space -> $(docker system df --format "{{.Size}}")"
}

# Wipes all Docker containers, volumes, images and builder cache.
_tools_docker_wipe() {
	_info "Wiping containers, volumes and images..."
	_say "$Y" "docker system prune -a --volumes -f"
	docker system prune -a --volumes -f
	sleep .5
	_nl

	_info "Wiping builder cache..."
	_say "$Y" "docker builder prune -a -f"
	docker builder prune -a -f
	sleep .5
	_nl

	_info "Cleaning hostnames..."
	_say "$Y" "ddev hostname --remove-inactive"
	ddev hostname --remove-inactive || true
	sleep .5
}

