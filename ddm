# Prints the full help and usage reference to stdout.
# Called via 'ddm -h|--help' and from the interactive main menu.
help() {
	local ddev_v docker_v is_installed="(disabled: see 'STATUS' above)"
	ddev_v="$(_ddev_version)"
	docker_v="$(_docker_version)"

	local bin_ok=false path_ok=false path_in_rc=false
	local s_installed="" s_skip="" s_path="" s_projects="" status_hint="All is good :)"
	[[ -x "$DDM_BIN" ]]                       && bin_ok=true
	[[ ":$PATH:" == *":$HOME/.local/bin:"* ]] && path_ok=true
	if ! $path_ok; then
		for _f in "$HOME/.bashrc" "$HOME/.zshrc"; do
			grep -qE "^[^#]*[$]HOME/.local/bin" "$_f" 2>/dev/null && path_in_rc=true && break
		done
	fi

	if [[ -x "$DDM_BIN" ]] && { $path_ok || $path_in_rc; }; then
		is_installed="Check/install updates"
	fi

	$bin_ok && s_installed="Yes" || s_installed="No"
	if $path_ok; then
		s_path="Ok"
	elif $path_in_rc; then
		s_path="Configured (reload shell to apply)"
	else
		s_path="Missing"
	fi
	[[ -n "$(_conf_get install_skip)" ]] && s_skip="True" || s_skip="False"

	if [[ "$s_skip" == "True" ]]; then
		status_hint="run '$(basename "$0") -r' to fix"
	elif ! $bin_ok || { ! $path_ok && ! $path_in_rc; }; then
		status_hint="run '$(basename "$0")' to setup"
	fi

	if [[ -n "$ddev_v" ]]; then
	    local _proj_count
	    _proj_count="$(_get_ddev_projects 2>/dev/null | wc -l)"
	    _proj_count="${_proj_count// /}"
	    [[ "$_proj_count" -gt 0 ]] && s_projects="$_proj_count" || s_projects="none yet"
	else
	    s_projects="n/a"
	fi

	local status_color="$Y"
	{ $bin_ok && $path_ok; } && status_color="$G"

	_printbox "$M" "$DDM_INFO - Help"
	cat <<-EOF
	${C}Author:${NC}  Salvatore Noschese
	${C}BlogURL:${NC} https://SalvatoreNoschese.it
	${C}Donate:${NC}  https://PayPal.me/SalvatoreN
	${C}GitHub:${NC}  https://github.com/SalvatoreNoschese

	${B}> STATUS${NC}    ${status_color}${status_hint}${NC}
	${C}Installed:${NC}  $s_installed
	${C}Skip Flag:${NC}  $s_skip
	${C}SystemPath:${NC} $s_path
	${C}Projects:${NC}   $s_projects
	${C}Script:${NC}     $(realpath "$0")
	${C}Config:${NC}     $([[ -f "$DDM_CONF" ]] && echo "$DDM_CONF" || echo "not set")
	${C}WorkDir:${NC}    $(_get_workspace_path)
	${C}DDEV:${NC}       ${ddev_v:-not installed}
	${C}Docker:${NC}     ${docker_v:-not installed}

	${B}> USAGE${NC}
	${G}ddm${NC}                Interactive menu (recommended)
	${G}ddm -h${NC}|${G}--help${NC}      Show this help
	${G}ddm -l${NC}|${G}--list${NC}      List all projects
	${G}ddm -p${NC}|${G}--poweroff${NC}  DDEV poweroff
	${G}ddm -r${NC}|${G}--reset${NC}     Reset all configuration
	${G}ddm -s${NC}|${G}--stopall${NC}   Stop all running projects
	${G}ddm -u${NC}|${G}--update${NC}    $is_installed
	${G}ddm -v${NC}|${G}--version${NC}   Show ddm version

	${B}> NOTE${NC}
	Project management (start, stop, delete, etc.)
	is available from the interactive menu: just run '${G}ddm${NC}'

	${B}> SUPPORTED PLATFORMS${NC} (${#PROJECT_TYPES[@]})
	${C}CMS:${NC} ${#PROJECT_TYPES_CMS[@]} | ${C}Framework:${NC} ${#PROJECT_TYPES_FRAMEWORK[@]} | ${C}Extra:${NC} ${#PROJECT_TYPES_EXTRA[@]}

	${B}> DATABASE CREDENTIALS${NC} (all projects with a DB)
	${C}Host:${NC} db | ${C}Name:${NC} db | ${C}User:${NC} db | ${C}Password:${NC} db
	${Y}* For local development only — never use in production!${NC}

	${B}> RESOURCES${NC}
	$DDEV_DOCS_URL
	$DOCKER_DOCS_URL
	EOF
}

# Returns 0 if ddm is properly installed: binary exists and PATH is active.
_ddm_is_installed() {
	[[ -x "$DDM_BIN" ]] && [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]
}

# =========== #
# CLI HANDLER #
# =========== #

handle_cli() {
	# Guard for operational commands: verifies ddev and jq are available.
	# -v, -h, -r skip this check intentionally — they need no system deps.
	_cli_require() {
		local missing=()
		command -v ddev &>/dev/null || missing+=("ddev")
		command -v jq   &>/dev/null || missing+=("jq")
		if (( ${#missing[@]} )); then
			_error "Missing: ${missing[*]}. Run 'ddm' to install dependencies."
			exit 1
		fi
	}

	case "${1:-}" in
	-v | --version)
		printf "%s\n" "$DDM_INFO"
		;;
	-h | --help)
		help
		_nl
		;;
	-r | --reset)
		if [[ -f "$DDM_CONF" ]]; then
			rm -f "$DDM_CONF"
			_done "Configuration reset."
			_say "$B" "Run 'ddm' to reconfigure."
		else
			_warn "No configuration file found, nothing to reset."
		fi
		;;
	-l | --list)
		_cli_require
		local projects_raw
		projects_raw="$(_get_ddev_projects)"
		if [[ -z "$projects_raw" ]]; then
			_warn "No DDEV projects found."
		else
			printf "%s\n" "$projects_raw" | column -t -s'|'
		fi
		;;
	-s | --stopall)
		_cli_require
		local projects_raw
		projects_raw="$(_get_ddev_projects)"
		if [[ -z "$projects_raw" ]]; then
			_warn "No DDEV projects found."
		elif ! _has_running_projects "$projects_raw"; then
			_info "No running projects."
		else
			stop_all
		fi
		;;
	-p | --poweroff)
		_cli_require
		_tools_poweroff
		;;
	-u | --update)
		_cli_require
		if ! _ddm_is_installed; then
			_warn "ddm is not properly installed — see Status in 'ddm -h'."
			exit 1
		else
			check_updates true
		fi
		;;
	*)
		printf "\n%s\n" "Unknown option: $1"
		printf "%s\n\n" "Run 'ddm -h' for help."
		exit 1
		;;
	esac
}

# ============== #
# MAIN EXECUTION #
# ============== #

if [[ $# -eq 0 ]]; then
	check_system
	while true; do
		_main_menu
	done
else
	handle_cli "$@"
fi
