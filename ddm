# Joomla
install_joomla() {
	local name="$1"
	_setup_project_dir "$name" || return 1
	local download_url=""

	download_url="$(
		curl -fsSL https://api.github.com/repos/joomla/joomla-cms/releases/latest |
			jq -r '.assets | map(select(.name | test("^Joomla.*Stable-Full_Package\\.zip$")))[0].browser_download_url'
	)"

	if [[ -z "$download_url" || "$download_url" == "null" || "$download_url" != https://* ]]; then
		_error "Could not fetch Joomla download URL from GitHub API (rate limit, connectivity issue, or API change)."
		_info "Tip: try again later, or test connectivity with: curl -I https://api.github.com/"
		return 1
	fi

	_info "Downloading: ${download_url##*/}"
	trap 'rm -f joomla.zip' RETURN
	curl --max-time 300 -fL --retry 3 --retry-delay 2 -o joomla.zip "$download_url" || {
		_error "Download failed"
		return 1
	}

	unzip -q joomla.zip || {
		_error "Unzip failed"
		return 1
	}
	rm -f joomla.zip; trap - RETURN

	_info "Configuring DDEV..."
	ddev config --project-type=php --webserver-type=apache-fpm --upload-dirs=images || {
		_error "DDEV config failed"
		return 1
	}
	_ddev_start || return 1

	_info "Installing Joomla via CLI..."
	ddev php installation/joomla.php install \
		--site-name="Dev Joomla" \
		--admin-user="Administrator" \
		--admin-username=admin \
		--admin-password=AdminAdmin1! \
		--admin-email=admin@example.com \
		--db-type=mysql \
		--db-encryption=0 \
		--db-host=db \
		--db-user=db \
		--db-pass="db" \
		--db-name=db \
		--db-prefix=ddev_ \
		--public-folder="" || {
		_error "Joomla install failed"
		return 1
	}

	_finalize_installation "$name" "admin" "AdminAdmin1!" ""
}

