# Read a value from ddm.conf. Usage: _conf_get "key"
_conf_get() {
	local key="$1"
	[[ -f "$DDM_CONF" ]] || { echo ""; return 1; }
	grep -m1 "^${key}=" "$DDM_CONF" 2>/dev/null | cut -d= -f2-
}

# Write/update a key in ddm.conf. Usage: _conf_set "key" "value"
_conf_set() {
	local key="$1" value="$2"
	mkdir -p "$DDM_CONFIG_DIR"
	if [[ -f "$DDM_CONF" ]] && grep -q "^${key}=" "$DDM_CONF" 2>/dev/null; then
		sed -i "s;^${key}=.*;${key}=${value};" "$DDM_CONF"
	else
		printf '%s=%s\n' "$key" "$value" >> "$DDM_CONF"
	fi
}

# ====== #
# COLORS #
# ====== #

# Bright
R=$'\033[1;31m' # Red
G=$'\033[1;32m' # Green
Y=$'\033[1;33m' # Yellow
B=$'\033[1;34m' # Blue
M=$'\033[1;35m' # Magenta
C=$'\033[1;36m' # Cyan
# Reset
NC=$'\033[0m'

# ================= #
# OUTPUT PRIMITIVES #
# ================= #

_info()  { printf "${B}[i]${NC} %s\n" "$1"; }
_done()  { printf "${G}[✓]${NC} %s\n" "$1"; }
_warn()  { printf "${Y}[!]${NC} %s\n" "$1"; }
_error() { printf "${R}[✗]${NC} %s\n" "$1" >&2; }
_nl()    { printf "\n"; }

# Displays an indented line with a leading arrow symbol.
# First argument is always the arrow color (or "" for plain/neutral).
# Remaining arguments are the text to display.
#   _say "$Y" "simple warning"       # yellow arrow — shell command
#   _say "$B" "some note"            # blue arrow   — informational context
#   _say ""   "a path or URL"        # plain arrow  — neutral
#   _say ""   "${G}colored txt${NC}" # plain arrow  — pre-colored string
_say() {
	local color="$1"
	shift
	printf " %s>%s  %s\n" "$color" "$NC" "$*"
}

# Renders a bordered box around a single-line title.
# Usage: _printbox "$COLOR" "Title Text"
_printbox() {
	local color="$1" text="$2" pad=1 line=""
	local text_len="${#text}"
	local inner=$((text_len + pad * 2))
	for ((i = 0; i < inner; i++)); do line+="═"; done
	printf "\n"
	printf "%s╔%s╗%s\n" "$color" "$line" "$NC"
	printf "%s║%*s%s%*s║%s\n" "$color" "$pad" "" "$text" "$pad" "" "$NC"
	printf "%s╚%s╝%s\n" "$color" "$line" "$NC"
	printf "\n"
}

# Returns the installed DDEV version string (e.g. "v1.23.4"), or empty if not installed.
_ddev_version() {
	ddev --version 2>/dev/null | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | head -n1
}

# Returns the installed Docker version string (e.g. "v27.3.1"), or empty if not installed.
_docker_version() {
	docker --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -n1 | sed 's/^/v/'
}

# ====================== #
# PROJECT TYPES REGISTRY #
# ====================== #
# Format per entry: "key:Display Name:prefix:admin_path"
# key        — maps to install_<key>() (hyphens normalized to underscores)
# prefix     — prepended to project names, e.g. wp-myblog
# admin_path — admin URL path (empty if none)
#
# Category is implicit in each source array — injected into PROJECT_TYPES at build time.

PROJECT_TYPES_CMS=(
	"wordpress:WordPress:wp:/wp-admin"
	"drupal10:Drupal 10:dr10:/user/login"
	"drupal11:Drupal 11:dr11:/user/login"
	"drupal-cms:Drupal CMS:drcms:/user/login"
	"backdrop:Backdrop CMS:bd:/user/login"
	"joomla:Joomla:joo:/administrator"
	"typo3:TYPO3 v14:t3:/typo3"
	"craft:Craft CMS:cf:/admin"
	"statamic:Statamic CMS:st:/cp"
	"shopware6:Shopware 6:sw:/admin"
	"grav:Grav CMS:grv:/admin"
	"kirby:Kirby CMS:kb:/panel"
	"contao:Contao CMS:cnt:/contao"
	"winter-cms:Winter CMS:win:/backend"
	"processwire:ProcessWire:pw:/processwire"
)

PROJECT_TYPES_FRAMEWORK=(
	"laravel:Laravel:lrv:"
	"symfony:Symfony:sf:"
	"cakephp:CakePHP:cake:"
	"codeigniter:CodeIgniter:ci:"
	"php-generic:PHP Generic:php:"
)

PROJECT_TYPES_EXTRA=(
	"classicpress:ClassicPress:cp:/wp-admin"
	"moodle:Moodle LMS:mdl:/login"
	"prestashop:PrestaShop:ps:/"
	"flarum:Flarum - Forum:flr:/admin"
	"matomo:Matomo Analytics:mat:/"
)

# Build combined PROJECT_TYPES array at startup.
# Category is injected from the source array name: key:label:prefix:cat:admin_path
PROJECT_TYPES=()
for _e in "${PROJECT_TYPES_CMS[@]}";       do IFS=':' read -r _k _l _p _a <<<"$_e"; PROJECT_TYPES+=("$_k:$_l:$_p:cms:$_a");       done
for _e in "${PROJECT_TYPES_FRAMEWORK[@]}"; do IFS=':' read -r _k _l _p _a <<<"$_e"; PROJECT_TYPES+=("$_k:$_l:$_p:framework:$_a"); done
for _e in "${PROJECT_TYPES_EXTRA[@]}";     do IFS=':' read -r _k _l _p _a <<<"$_e"; PROJECT_TYPES+=("$_k:$_l:$_p:extra:$_a");     done
unset _e _k _l _p _a

# Parses a raw PROJECT_TYPES entry into named fields via a Bash 4.3 nameref.
# Usage:
#   local -A t
#   _parse_type_entry "$entry" t
#   echo "${t[key]} ${t[label]} ${t[prefix]} ${t[cat]} ${t[admin]}"
_parse_type_entry() {
	local _raw="$1"
	local -n _t="$2"
	IFS=':' read -r '_t[key]' '_t[label]' '_t[prefix]' '_t[cat]' '_t[admin]' <<<"$_raw"
}

