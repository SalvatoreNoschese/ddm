# ProcessWire
install_processwire() {
	local name="$1"
	_setup_project_dir "$name" || return 1
	local notes="Browser installer: DB host=db  DB name=db  DB user=db  DB pass=db"
	notes+="  |  Keep the default admin path (/processwire) — if customized, the admin URL won't display correctly."

	_info "Downloading ProcessWire..."
	trap 'rm -f processwire-master.zip' RETURN
	curl -LJOf https://github.com/processwire/processwire/archive/master.zip || {
		_error "Download failed"
		return 1
	}
	unzip -q processwire-master.zip || {
		_error "Unzip failed"
		return 1
	}
	rm -f processwire-master.zip; trap - RETURN
	if [[ -d "processwire-master" ]]; then
		(
			shopt -s dotglob
			mv processwire-master/* .
		)
		mv processwire-master/.* . 2>/dev/null || true
		rm -rf processwire-master
	fi

	_info "Configuring ProcessWire..."
	ddev config --project-type=php --webserver-type=apache-fpm || {
		_error "DDEV config failed"
		return 1
	}
	_ddev_start || return 1

	_finalize_installation "$name" "" "" "$notes"
}

